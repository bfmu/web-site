---
import { Icon } from 'astro-icon/components'
import DisplaySettings from './widget/DisplaySettings.svelte'
import { LinkPreset, type NavBarLink } from '../types/config'
import { navBarConfig, siteConfig } from '../config'
import NavMenuPanel from './widget/NavMenuPanel.astro'
import Search from './Search.svelte'
import { LinkPresets } from '../constants/link-presets'
import LightDarkSwitch from './LightDarkSwitch.svelte'
import { url } from '../utils/url-utils'
const className = Astro.props.class

let links: NavBarLink[] = navBarConfig.links.map(
  (item: NavBarLink | LinkPreset): NavBarLink => {
    if (typeof item === 'number') {
      return LinkPresets[item]
    }
    return item
  },
)
---
<div id="navbar" class="z-50 onload-animation">
    <div class="absolute h-8 left-0 right-0 -top-8 bg-[var(--card-bg)] transition"></div> <!-- used for onload animation -->
    <div class:list={[
        className,
        "card-base overflow-visible max-w-[var(--page-width)] h-[4.5rem] rounded-t-none mx-auto flex items-center justify-between px-4"]}>
        <a href={url('/')} class="btn-plain scale-animation rounded-lg h-[3.25rem] px-5 font-bold active:scale-95">
            <div class="flex flex-row text-[var(--primary)] items-center text-md">
                <Icon name="material-symbols:home-outline-rounded" class="text-[1.75rem] mb-1 mr-2" />
                {siteConfig.title}
            </div>
        </a>
        <div class="hidden md:flex">
            {links.map((l) => {
                return <a aria-label={l.name} href={l.external ? l.url : url(l.url)} target={l.external ? "_blank" : null}
                          class="btn-plain scale-animation rounded-lg h-11 font-bold px-5 active:scale-95"
                >
                    <div class="flex items-center">
                        {l.name}
                        {l.external && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.875rem] transition -translate-y-[1px] ml-1 text-black/[0.2] dark:text-white/[0.2]"></Icon>}
                    </div>
                </a>;
            })}
        </div>
        <div class="flex">
            <!--<SearchPanel client:load>-->
            <Search client:only="svelte">
                <Icon slot="search-icon" name="material-symbols:search" class="absolute text-[1.25rem] pointer-events-none ml-3 transition my-auto text-black/30 dark:text-white/30"></Icon>
                <Icon slot="arrow-icon" name="fa6-solid:chevron-right" class="transition text=[0.75rem] translate-x-0.5 my-auto text-[var(--primary)]"></Icon>
                <Icon slot="search-switch" name="material-symbols:search" class="text-[1.25rem]"></Icon>
            </Search>
            {!siteConfig.themeColor.fixed && (
                    <button aria-label="Display Settings" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="display-settings-switch">
                        <Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
                    </button>
            )}
            <LightDarkSwitch client:load></LightDarkSwitch>
                <!-- Admin/Login Button with Dropdown -->
                <div id="admin-user-menu" class="relative hidden flex-shrink-0" role="menu" tabindex="-1">
                <button 
                    id="admin-user-btn" 
                    aria-label="Menú de usuario" 
                    class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90 flex items-center justify-center overflow-hidden"
                    title="Menú de usuario"
                >
                    <img 
                        id="admin-user-avatar" 
                        src="/default-avatar.svg" 
                        alt="Avatar" 
                        class="w-full h-full object-cover rounded-full border-2 border-gray-200 dark:border-gray-700"
                        onerror="this.src='/default-avatar.svg'"
                    />
                </button>
                <!-- Dropdown Menu -->
                <div id="admin-user-dropdown" class="absolute right-0 top-12 mt-2 w-48 card-base float-panel float-panel-closed" style="z-index: 9999;">
                    <div class="p-2">
                        <a 
                            href="/admin/profile" 
                            class="flex items-center gap-3 px-3 py-2 rounded-lg btn-plain scale-animation transition whitespace-nowrap h-9 font-medium active:scale-95 mb-0.5"
                        >
                            <Icon name="material-symbols:person" class="text-[1.25rem]"></Icon>
                            <span class="text-sm">Mi Perfil</span>
                        </a>
                        <a 
                            id="admin-dashboard-link"
                            href="/admin" 
                            class="flex items-center gap-3 px-3 py-2 rounded-lg btn-plain scale-animation transition whitespace-nowrap h-9 font-medium active:scale-95 mb-0.5"
                        >
                            <Icon name="material-symbols:dashboard" class="text-[1.25rem]"></Icon>
                            <span class="text-sm">Dashboard</span>
                        </a>
                        <hr id="admin-dashboard-divider" class="my-2 border-[var(--line-divider)]" />
                        <button 
                            id="logout-menu-btn"
                            class="w-full flex items-center gap-3 px-3 py-2 rounded-lg btn-plain scale-animation transition whitespace-nowrap h-9 font-medium active:scale-95 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20"
                        >
                            <Icon name="material-symbols:logout" class="text-[1.25rem]"></Icon>
                            <span class="text-sm">Cerrar Sesión</span>
                        </button>
                    </div>
                </div>
            </div>
            <!-- Login Button (shown when not authenticated) -->
            <a 
                id="admin-login-btn" 
                href="/admin/login" 
                aria-label="Admin Login" 
                class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90 flex items-center justify-center flex-shrink-0"
                title="Iniciar sesión"
            >
                <Icon id="admin-login-icon" name="material-symbols:person" class="text-[1.25rem]"></Icon>
            </a>
            <button aria-label="Menu" name="Nav Menu" class="btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 md:hidden" id="nav-menu-switch">
                <Icon name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
            </button>
        </div>
        <NavMenuPanel links={links}></NavMenuPanel>
        <DisplaySettings client:only="svelte">
            <Icon slot="restore-icon" name="fa6-solid:arrow-rotate-left" class="text-[0.875rem]"></Icon>
        </DisplaySettings>
    </div>
</div>

<!-- Logout Confirmation Modal -->
<div
    id="navbar-logout-modal"
    class="fixed inset-0 hidden items-center justify-center bg-black/50 p-4"
    style="z-index: 10000;"
>
    <div class="bg-[var(--card-bg)] rounded-lg shadow-xl max-w-md w-full p-6 animate-fade-in border border-[var(--line-divider)]">
        <div class="flex items-center gap-3 mb-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-amber-100 dark:bg-amber-900/20 flex items-center justify-center">
                <Icon name="material-symbols:warning-rounded" class="text-[1.5rem] text-amber-600 dark:text-amber-400"></Icon>
            </div>
            <div class="flex-1">
                <h3 class="text-lg font-semibold" style="color: var(--primary);">
                    Cerrar Sesión
                </h3>
                <p class="text-sm opacity-70 mt-1" style="color: var(--primary);">
                    ¿Estás seguro de que quieres cerrar sesión?
                </p>
            </div>
        </div>
        <div class="flex gap-3 justify-end mt-6">
            <button
                id="navbar-logout-cancel-btn"
                class="px-4 py-2 rounded-lg transition-colors font-medium btn-plain"
            >
                Cancelar
            </button>
            <button
                id="navbar-logout-confirm-btn"
                class="px-4 py-2 rounded-lg text-white bg-red-600 hover:bg-red-700 dark:bg-red-500 dark:hover:bg-red-600 transition-colors font-medium"
            >
                Cerrar Sesión
            </button>
        </div>
    </div>
</div>

<script data-swup-reload-script>
  import { initNavbar } from '../lib/navbar-init';
  initNavbar();
</script>
