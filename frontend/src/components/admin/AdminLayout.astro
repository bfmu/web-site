---
import Layout from '@layouts/Layout.astro';
import AdminThemeSwitch from '@components/admin/AdminThemeSwitch.svelte';
import { getUser } from '../../lib/auth';

interface Props {
  title?: string;
}

const { title = 'Admin' } = Astro.props;

// En SSR, no podemos acceder a localStorage, así que getUser() retornará null
// No hacer redirect aquí, el middleware y el cliente se encargan de la protección
// Solo obtener el usuario si está disponible (en el cliente)
let user = null;
if (typeof window !== 'undefined') {
  user = getUser();
}
---

<Layout title={title}>
  <div class="admin-layout flex min-h-screen flex-col bg-gray-50 dark:bg-gray-900 lg:flex-row">
    <!-- Sidebar: móvil=fixed overlay, desktop=in-flow colapsable -->
    <aside
      id="admin-sidebar"
      class="admin-sidebar fixed left-0 top-0 z-40 h-screen w-64 -translate-x-full overflow-x-hidden border-r border-gray-200 bg-white transition-[transform,width] duration-200 ease-out dark:border-gray-700 dark:bg-gray-800 lg:sticky lg:top-0 lg:translate-x-0 lg:w-16 lg:hover:w-64 lg:self-start"
    >
      <div class="flex h-full w-64 flex-col lg:w-64">
        <!-- Logo/Title -->
        <div class="admin-nav-link flex h-16 shrink-0 items-center border-b border-gray-200 px-4 dark:border-gray-700">
          <svg class="h-6 w-6 shrink-0 text-gray-700 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2a2 2 0 012-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2a2 2 0 012-2z" />
          </svg>
          <span class="text-lg font-bold text-gray-900 dark:text-white">Admin Panel</span>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 space-y-1 px-3 py-4">
          <a
            href="/admin"
            data-admin-only="true"
            class:list={[
              "hidden admin-link admin-nav-link flex items-center gap-3 rounded-lg px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700",
              {
                'bg-gray-100 dark:bg-gray-700': Astro.url.pathname === '/admin',
              },
            ]}
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
              />
            </svg>
            <span>Dashboard</span>
          </a>

          <a
            href="/admin/posts"
            data-admin-only="true"
            class:list={[
              "hidden admin-link admin-nav-link flex items-center gap-3 rounded-lg px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700",
              {
                'bg-gray-100 dark:bg-gray-700': Astro.url.pathname.startsWith('/admin/posts'),
              },
            ]}
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              />
            </svg>
            <span>Posts</span>
          </a>

          <a
            href="/admin/media"
            data-admin-only="true"
            class:list={[
              "hidden admin-link admin-nav-link flex items-center gap-3 rounded-lg px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700",
              {
                'bg-gray-100 dark:bg-gray-700': Astro.url.pathname.startsWith('/admin/media'),
              },
            ]}
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
            <span>Media</span>
          </a>

          <a
            href="/admin/albums"
            data-admin-only="true"
            class:list={[
              "hidden admin-link admin-nav-link flex items-center gap-3 rounded-lg px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700",
              {
                'bg-gray-100 dark:bg-gray-700': Astro.url.pathname.startsWith('/admin/albums'),
              },
            ]}
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
              />
            </svg>
            <span>Álbumes</span>
          </a>

          <a
            href="/admin/homepage"
            data-admin-only="true"
            class:list={[
              "hidden admin-link admin-nav-link flex items-center gap-3 rounded-lg px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700",
              {
                'bg-gray-100 dark:bg-gray-700': Astro.url.pathname === '/admin/homepage',
              },
            ]}
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
              />
            </svg>
            <span>Página de inicio</span>
          </a>

          <a
            href="/admin/users"
            data-admin-only="true"
            class:list={[
              "hidden admin-link admin-nav-link flex items-center gap-3 rounded-lg px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700",
              {
                'bg-gray-100 dark:bg-gray-700': Astro.url.pathname.startsWith('/admin/users'),
              },
            ]}
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
              />
            </svg>
            <span>Usuarios</span>
          </a>

          <a
            href="/admin/profile"
            class="admin-nav-link flex items-center gap-3 rounded-lg px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700"
            class:list={[
              {
                'bg-gray-100 dark:bg-gray-700': Astro.url.pathname === '/admin/profile',
              },
            ]}
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
              />
            </svg>
            <span>Mi Perfil</span>
          </a>

          <!-- Separador visual -->
          <div class="my-2 border-t border-gray-200 dark:border-gray-700"></div>

          <a
            href="/admin/services"
            id="services-link"
            class="hidden admin-nav-link flex items-center gap-3 rounded-lg px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700"
            class:list={[
              {
                'bg-gray-100 dark:bg-gray-700': Astro.url.pathname.startsWith('/admin/services'),
              },
            ]}
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </svg>
            <span>Servicios</span>
          </a>

          <a
            href="/admin/backup"
            id="backup-link"
            class="hidden admin-nav-link flex items-center gap-3 rounded-lg px-3 py-2 text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700"
            class:list={[
              {
                'bg-gray-100 dark:bg-gray-700': Astro.url.pathname.startsWith('/admin/backup'),
              },
            ]}
          >
            <span class="text-lg">💾</span>
            <span>Backup y Restauración</span>
          </a>
          
        </nav>
      </div>
    </aside>

    <!-- Mobile sidebar overlay -->
    <div
      id="sidebar-overlay"
      class="fixed inset-0 z-30 bg-gray-900/50 opacity-0 transition-opacity lg:hidden"
      style="pointer-events: none;"
    ></div>

    <!-- Logout Confirmation Modal -->
    <div
      id="logout-modal"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
    >
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full p-6 animate-fade-in">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-amber-100 dark:bg-amber-900/20 flex items-center justify-center">
            <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
              Cerrar Sesión
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
              ¿Estás seguro de que quieres cerrar sesión?
            </p>
          </div>
        </div>
        <div class="flex gap-3 justify-end mt-6">
          <button
            id="logout-cancel-btn"
            class="px-4 py-2 rounded-lg text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors font-medium"
          >
            Cancelar
          </button>
          <button
            id="logout-confirm-btn"
            class="px-4 py-2 rounded-lg text-white bg-red-600 hover:bg-red-700 dark:bg-red-500 dark:hover:bg-red-600 transition-colors font-medium"
          >
            Cerrar Sesión
          </button>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <div class="admin-main flex-1 min-w-0 lg:pl-0">
      <!-- Top bar -->
      <header class="sticky top-0 z-30 flex h-16 items-center gap-4 border-b border-gray-200 bg-white px-4 shadow-sm dark:border-gray-700 dark:bg-gray-800 lg:px-6 overflow-visible">
        <button
          id="sidebar-toggle"
          class="lg:hidden"
          aria-label="Toggle sidebar"
        >
          <svg
            class="h-6 w-6 text-gray-600 dark:text-gray-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
        </button>

        <div class="flex-1">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
            {title}
          </h2>
        </div>

        <div class="flex items-center gap-2 overflow-visible">
          <div class="flex items-center">
            <AdminThemeSwitch client:load></AdminThemeSwitch>
          </div>
          <!-- User menu dropdown (top right) -->
          <div id="admin-header-user-menu" class="relative flex-shrink-0" role="menu" tabindex="-1">
            <button
              id="admin-header-user-btn"
              aria-label="Menú de usuario"
              class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-full border-2 border-gray-200 transition hover:border-gray-300 dark:border-gray-600 dark:hover:border-gray-500"
              title="Menú de usuario"
            >
              <img
                id="admin-header-avatar"
                src="/default-avatar.svg"
                alt="Avatar"
                class="h-full w-full object-cover rounded-full"
                onerror="this.src='/default-avatar.svg'"
              />
            </button>
            <div
              id="admin-header-user-dropdown"
              class="admin-user-dropdown absolute right-0 top-12 z-50 mt-2 w-56 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-xl dark:border-gray-700 dark:bg-gray-800 hidden"
            >
              <div class="p-3">
                <p id="admin-header-user-name" class="truncate text-sm font-medium text-gray-900 dark:text-white">
                  Cargando...
                </p>
                <p id="admin-header-user-email" class="truncate text-xs text-gray-500 dark:text-gray-400">
                  ...
                </p>
                <hr class="my-2 border-gray-200 dark:border-gray-700" />
                <button
                  id="logout-btn"
                  class="flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-red-600 transition-colors hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20"
                >
                  <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2v1" />
                  </svg>
                  Cerrar Sesión
                </button>
              </div>
            </div>
          </div>
          <a
            id="go-to-site-link"
            href="/"
            class="hidden rounded-lg px-3 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700 flex items-center gap-1.5 h-11"
            title="Ir al sitio principal"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
            Ir al Sitio
          </a>
        </div>
      </header>

      <!-- Page content -->
      <main class="p-4 lg:p-6">
        <slot />
      </main>
    </div>
  </div>
</Layout>

<script data-swup-reload-script>
  import { getUser, isAuthenticated, isAdmin } from '../../lib/auth';
  import { navigateTo } from '../../lib/navigation';
  import { initAdmin } from '../../lib/admin-init';

  // Verificar autenticación en el cliente y redirigir si es necesario
  if (!isAuthenticated()) {
    navigateTo('/admin/login');
    // initAdmin no se ejecuta si hay redirect
  } else {
    initAdmin();
  }

  // Si el usuario NO es admin ni editor, solo puede ver su perfil
  const currentUser = getUser();
  const userIsAdmin = currentUser && isAdmin();
  const userIsEditor = currentUser && currentUser.role === 'editor';
  const hasAdminAccess = userIsAdmin || userIsEditor;
  if (currentUser && !hasAdminAccess) {
    const currentPath = window.location.pathname;
    if (currentPath !== '/admin/profile') {
      import('../../lib/notifications').then(({ showWarning }) => {
        showWarning('No tienes permisos para acceder al panel de administración.');
      });
      navigateTo('/admin/profile');
    }
  }

  // Los event listeners (logout, sidebar) se configuran en admin-init.ts
  // para funcionar tanto en carga directa como en transiciones Swup.
</script>

<style>
  /* Admin: sidebar colapsable en desktop, empuja contenido */
  @media (min-width: 1024px) {
    .admin-layout {
      display: flex;
      flex-direction: row;
    }
    .admin-sidebar {
      width: 4rem;
      flex-shrink: 0;
    }
    .admin-sidebar:hover {
      width: 16rem;
    }
    .admin-sidebar .admin-nav-link span {
      opacity: 0;
      width: 0;
      overflow: hidden;
      white-space: nowrap;
      transition: opacity 0.15s ease-out, width 0.15s ease-out;
    }
    .admin-sidebar:hover .admin-nav-link span {
      opacity: 1;
      width: auto;
    }
  }
</style>

