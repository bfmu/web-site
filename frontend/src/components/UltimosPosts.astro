---
import { getPostUrlBySlug } from '@utils/url-utils'
import { fetchRecentPosts } from '@utils/api-blog'

const ultimosPosts = await fetchRecentPosts(3)

// Log para depuración de slugs y URLs generadas
console.log('[UltimosPosts] Slugs y URLs generadas:');
ultimosPosts.forEach(entry => {
  console.log('slug:', entry.slug, 'url:', getPostUrlBySlug(entry.slug));
});
---

<section class="w-full py-16 bg-[var(--card-bg)] text-center rounded-[var(--radius-large)] shadow-md">
    <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-[var(--primary)] dark:text-[var(--title-active)]">
            Últimos artículos
        </h2>
        <p class="text-lg text-[var(--deep-text)] dark:text-white mt-4">Explora las publicaciones más recientes de mi blog.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8 max-w-5xl mx-auto px-6">
        {ultimosPosts.map((entry) => (
            <a href={getPostUrlBySlug(entry.slug)} class="relative group overflow-hidden rounded-[var(--radius-large)] shadow-md block bg-[var(--btn-regular-bg)] hover:bg-[var(--btn-regular-bg-hover)] transition">
                {entry.image && (
                    <img src={entry.image} alt={entry.title} class="w-full h-48 object-cover transition group-hover:scale-105" />
                )}
                <div class="p-6 text-left">
                    <h3 class="text-xl font-semibold text-[var(--primary)] dark:text-[var(--title-active)]">{entry.title}</h3>
                    <p class="text-[var(--deep-text)] dark:text-white mt-2 line-clamp-3">{entry.description}</p>
                    <span class="text-sm text-[var(--deep-text)] dark:text-gray-300 mt-4 block">{new Date(entry.published).toLocaleDateString()}</span>
                </div>
                <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-10 transition"></div>
            </a>
        ))}
    </div>
</section>
