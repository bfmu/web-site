---
import { getPostUrlBySlug } from "@utils/url-utils";
import PostCard from "./PostCard.astro";

const { page } = Astro.props;


const transformedData = page.data.map((post: any) => ({
  slug: post.slug,
  data: {
    draft: post.draft,
    title: post.title,
    tags: post.tags,
    category: post.category,
    published: new Date(post.published),
    image: post.image,
    description: post.description,
  },
}));

let delay = 0;
const interval = 50;
---

<div
  class="transition flex flex-col rounded-[var(--radius-large)] bg-[var(--card-bg)] py-1 md:py-0 md:bg-transparent md:gap-4 mb-4"
>
  {
    transformedData.map((entry, index) => {
      return (
        <PostCard
          entry={entry}
          title={entry.data.title}
          tags={entry.data.tags}
          category={entry.data.category}
          published={entry.data.published}
          url={getPostUrlBySlug(entry.slug)}
          image={entry.data.image}
          description={entry.data.description}
          draft={entry.data.draft}
          class:list="onload-animation"
          style={`animation-delay: calc(var(--content-delay) + ${index * interval}ms);`}
        />
      );
    })
  }
</div>
