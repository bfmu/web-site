---
import { Icon } from 'astro-icon/components'
import { i18n } from '../../i18n/translation'
import I18nKey from '../../i18n/i18nKey'
import { url } from '../../utils/url-utils'

interface Props {
  class?: string
  style?: string
}
const className = Astro.props.class
const style = Astro.props.style
---

<a 
    href={url('/archive/')}
    aria-label="Ver archivo completo de posts"
    class:list={[
        "group card-base p-4 transition-all hover:scale-[1.02] active:scale-[0.98]",
        "flex items-center gap-4",
        "hover:bg-[var(--btn-plain-bg-hover)] active:bg-[var(--btn-plain-bg-active)]",
        className
    ]}
    style={style}
>
    <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-[var(--primary)]/10 dark:bg-[var(--primary)]/20 flex items-center justify-center transition-transform group-hover:scale-110">
        <Icon name="material-symbols:archive-outline-rounded" class="text-2xl text-[var(--primary)]"></Icon>
    </div>
    <div class="flex-1 min-w-0">
        <div class="font-bold text-lg text-neutral-900 dark:text-neutral-100 transition group-hover:text-[var(--primary)]">
            {i18n(I18nKey.archive)}
        </div>
        <div class="text-sm text-neutral-500 dark:text-neutral-400 mt-0.5">
            Ver todos los posts
        </div>
    </div>
    <Icon name="fa6-solid:chevron-right" class="text-lg text-neutral-400 dark:text-neutral-500 transition-transform group-hover:translate-x-1 group-hover:text-[var(--primary)]"></Icon>
</a>

