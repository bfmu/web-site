---
import MainGridLayout from '@layouts/MainGridLayout.astro'
import PostsArchive from '@/components/PostsArchive.jsx'
import { fetchPosts } from '@/utils/api-blog'
import { i18n } from '@i18n/translation'
import I18nKey from '@i18n/i18nKey'

// Puedes poner aquí tus filtros si quieres
const params = { page: 1 }
const res = await fetchPosts(params)
const initialPosts = res.posts || res
const initialPagination = res.pagination
const apiUrl = import.meta.env.PUBLIC_API_URL
const fetchUrlBase = apiUrl.endsWith('/') ? apiUrl + 'api/blog' : apiUrl + '/api/blog';
---

<MainGridLayout title={i18n(I18nKey.archive)}>
  <PostsArchive
    initialPosts={initialPosts}
    initialPagination={initialPagination}
    fetchUrlBase={fetchUrlBase}
    filterQuery=""
    client:load
  />
</MainGridLayout>
