---
import ArchivePanel from "@components/ArchivePanel.astro";
import I18nKey from "@i18n/i18nKey";
import { fetchPosts } from "@/utils/api-blog";
import PostsArchive from "@/components/PostsArchive.jsx";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";

// Puedes poner aquí tus filtros si quieres
const params = { tag: Astro.params.tag as string, page: 1 };
const res = await fetchPosts(params);
const initialPosts = res.posts || res;
const initialPagination = res.pagination;
const apiUrl = import.meta.env.PUBLIC_API_URL;
const fetchUrlBase = apiUrl.endsWith("/")
  ? apiUrl + "api/blog"
  : apiUrl + "/api/blog";
---

<MainGridLayout
  title={i18n(I18nKey.archive)}
  description={i18n(I18nKey.archive)}
>
  <!-- <ArchivePanel tags={[tag]} /> -->
  <PostsArchive
    initialPosts={initialPosts}
    initialPagination={initialPagination}
    fetchUrlBase={fetchUrlBase}
    filterQuery={`tag=${params.tag}`}
    client:load
  />
</MainGridLayout>
