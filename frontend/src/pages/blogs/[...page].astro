const { page } = Astro.props
const pageNum = Number(page?.[0] || 1)
const res = await fetchPosts({ page: pageNum, limit: PAGE_SIZE })


// Adaptar la respuesta
const pageData = {
  data: res.posts, // Aquí adaptamos
  currentPage: res.pagination.page,
  totalPages: res.pagination.pages,
  totalDocs: res.pagination.total,
  limit: res.pagination.limit
}

const len = pageData.data.length
---
<MainGridLayout>
    <PostPage page={pageData}></PostPage>
    <!-- <Pagination class="mx-auto onload-animation" page={pageData} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination> -->
</MainGridLayout>