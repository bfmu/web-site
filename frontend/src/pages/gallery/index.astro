---
import MainGridLayout from '@layouts/MainGridLayout.astro'
import { i18n } from '@i18n/translation'
import I18nKey from '@i18n/i18nKey'
import { fetchPublicAlbums } from '../../utils/api-blog'
import AlbumCard from '../../components/AlbumCard.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'

let albums = [];
let error = null;

try {
  const response = await fetchPublicAlbums();
  albums = response.albums || [];
} catch (e) {
  console.error('Error loading albums:', e);
  error = e;
}
---

<MainGridLayout title={i18n(I18nKey.gallery)} showProfile={false} showCategories={false} showTags={false} hideSidebar={true}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
        <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
            <!-- Breadcrumb -->
            <Breadcrumb 
                items={[
                    { label: i18n(I18nKey.gallery) }
                ]}
            />

            <!-- Header -->
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
                    {i18n(I18nKey.gallery)}
                </h1>
                <p class="text-gray-600 dark:text-gray-400">
                    Explora mis colecciones de imágenes
                </p>
            </div>

            <!-- Albums Grid -->
            {error ? (
                <div class="text-center text-red-600 dark:text-red-400 py-8">
                    Error al cargar los álbumes. Por favor, intenta más tarde.
                </div>
            ) : albums.length === 0 ? (
                <div class="text-center text-gray-500 dark:text-gray-400 py-8">
                    No hay álbumes disponibles en este momento.
                </div>
            ) : (
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
                    {albums.map((album: any) => (
                        <AlbumCard album={album} />
                    ))}
                </div>
            )}
        </div>
    </div>
</MainGridLayout>

