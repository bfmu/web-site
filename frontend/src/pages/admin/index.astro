---
import AdminLayout from '@components/admin/AdminLayout.astro';
import StatsCard from '@components/admin/StatsCard.astro';
import { getStats, getRecentPosts, getMostViewedPosts } from '../../lib/admin-api';
import type { BlogPost } from '../../lib/admin-api';

// Inicializar valores por defecto
let stats = {
  totalPosts: 0,
  publishedPosts: 0,
  draftPosts: 0,
  totalViews: 0,
  categoriesCount: 0,
  tagsCount: 0,
};
let recentPosts: BlogPost[] = [];
let mostViewed: BlogPost[] = [];

// Cargar datos de forma segura, manejando errores individualmente
try {
  stats = await getStats();
} catch (error) {
  console.error('Error loading stats:', error);
  // stats ya tiene valores por defecto
}

try {
  recentPosts = await getRecentPosts(5);
} catch (error) {
  console.error('Error loading recent posts:', error);
  recentPosts = [];
}

try {
  mostViewed = await getMostViewedPosts(5);
} catch (error) {
  console.error('Error loading most viewed posts:', error);
  mostViewed = [];
}
---

<AdminLayout title="Dashboard">
  <div class="space-y-6">
    <!-- Stats Grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <StatsCard
        title="Total Posts"
        value={stats.totalPosts}
        icon="📝"
      />
      <StatsCard
        title="Publicados"
        value={stats.publishedPosts}
        icon="✅"
      />
      <StatsCard
        title="Borradores"
        value={stats.draftPosts}
        icon="📄"
      />
      <StatsCard
        title="Vistas Totales"
        value={stats.totalViews}
        icon="👁️"
      />
      <StatsCard
        title="Categorías"
        value={stats.categoriesCount}
        icon="📁"
      />
      <StatsCard
        title="Tags"
        value={stats.tagsCount}
        icon="🏷️"
      />
    </div>

    <!-- Recent Posts and Most Viewed -->
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
      <!-- Recent Posts -->
      <div class="rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <div class="border-b border-gray-200 px-6 py-4 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
            Posts Recientes
          </h3>
        </div>
        <div class="divide-y divide-gray-200 dark:divide-gray-700">
          {recentPosts.length > 0 ? (
            recentPosts.map((post) => (
              <a
                href={`/admin/posts/${post.slug}`}
                data-no-swup
                class="block px-6 py-4 transition-colors hover:bg-gray-50 dark:hover:bg-gray-700"
              >
                <div class="flex items-center justify-between">
                  <div class="flex-1 min-w-0">
                    <p class="truncate text-sm font-medium text-gray-900 dark:text-white">
                      {post.title}
                    </p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                      {new Date(post.published).toLocaleDateString('es-ES', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </p>
                  </div>
                  {post.draft && (
                    <span class="ml-2 rounded-full bg-yellow-100 px-2 py-1 text-xs font-medium text-yellow-800 dark:bg-yellow-900/20 dark:text-yellow-400">
                      Borrador
                    </span>
                  )}
                </div>
              </a>
            ))
          ) : (
            <div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
              No hay posts recientes
            </div>
          )}
        </div>
        <div class="border-t border-gray-200 px-6 py-4 dark:border-gray-700">
          <a
            href="/admin/posts"
            class="text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400"
          >
            Ver todos los posts →
          </a>
        </div>
      </div>

      <!-- Most Viewed -->
      <div class="rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <div class="border-b border-gray-200 px-6 py-4 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
            Más Vistos
          </h3>
        </div>
        <div class="divide-y divide-gray-200 dark:divide-gray-700">
          {mostViewed.length > 0 ? (
            mostViewed.map((post) => (
              <a
                href={`/admin/posts/${post.slug}`}
                data-no-swup
                class="block px-6 py-4 transition-colors hover:bg-gray-50 dark:hover:bg-gray-700"
              >
                <div class="flex items-center justify-between">
                  <div class="flex-1 min-w-0">
                    <p class="truncate text-sm font-medium text-gray-900 dark:text-white">
                      {post.title}
                    </p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                      {(post.views || 0).toLocaleString()} vistas
                    </p>
                  </div>
                  <span class="ml-2 text-sm font-medium text-gray-600 dark:text-gray-400">
                    👁️ {post.views || 0}
                  </span>
                </div>
              </a>
            ))
          ) : (
            <div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
              No hay datos de vistas
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Analytics de Visitantes -->
    <div id="analytics-section" class="space-y-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
        Analytics de Visitantes
      </h2>
      <div id="analytics-stats-cards" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800 animate-pulse">
          <div class="h-4 w-24 rounded bg-gray-200 dark:bg-gray-700"></div>
          <div class="mt-2 h-8 w-16 rounded bg-gray-200 dark:bg-gray-700"></div>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800 animate-pulse">
          <div class="h-4 w-24 rounded bg-gray-200 dark:bg-gray-700"></div>
          <div class="mt-2 h-8 w-16 rounded bg-gray-200 dark:bg-gray-700"></div>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800 animate-pulse">
          <div class="h-4 w-24 rounded bg-gray-200 dark:bg-gray-700"></div>
          <div class="mt-2 h-8 w-16 rounded bg-gray-200 dark:bg-gray-700"></div>
        </div>
      </div>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <div id="analytics-top-pages" class="rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="border-b border-gray-200 px-6 py-4 dark:border-gray-700">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Páginas más visitadas</h3>
          </div>
          <div id="analytics-top-pages-body" class="divide-y divide-gray-200 dark:divide-gray-700">
            <div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">Cargando…</div>
          </div>
        </div>
        <div id="analytics-top-locations" class="rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="border-b border-gray-200 px-6 py-4 dark:border-gray-700">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Visitantes por ubicación</h3>
          </div>
          <div id="analytics-top-locations-body" class="divide-y divide-gray-200 dark:divide-gray-700">
            <div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">Cargando…</div>
          </div>
        </div>
        <div id="analytics-recent-visits" class="rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="border-b border-gray-200 px-6 py-4 dark:border-gray-700">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Últimas visitas</h3>
          </div>
          <div id="analytics-recent-visits-body" class="divide-y divide-gray-200 dark:divide-gray-700 max-h-80 overflow-y-auto">
            <div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">Cargando…</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
      <h3 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white">
        Acciones Rápidas
      </h3>
      <div class="flex flex-wrap gap-3">
        <a
          href="/admin/posts/new"
          data-no-swup
          class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-indigo-700"
        >
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 4v16m8-8H4"
            />
          </svg>
          Nuevo Post
        </a>
        <a
          href="/admin/posts"
          class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            />
          </svg>
          Ver Todos los Posts
        </a>
      </div>
    </div>
  </div>

  <script>
    import { getAnalyticsStats } from '../../lib/admin-api';

    (async function loadAnalytics() {
      const cardsEl = document.getElementById('analytics-stats-cards');
      const topPagesEl = document.getElementById('analytics-top-pages-body');
      const topLocationsEl = document.getElementById('analytics-top-locations-body');
      const recentVisitsEl = document.getElementById('analytics-recent-visits-body');
      if (!cardsEl || !topPagesEl || !topLocationsEl || !recentVisitsEl) return;

      try {
        const data = await getAnalyticsStats();

        cardsEl.innerHTML = `
          <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Total visitas</p>
                <p class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">${data.totalPageViews.toLocaleString()}</p>
              </div>
              <div class="rounded-full bg-indigo-100 p-3 dark:bg-indigo-900/20"><span class="text-2xl">📊</span></div>
            </div>
          </div>
          <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Visitantes únicos (24h)</p>
                <p class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">${data.uniqueVisitors.toLocaleString()}</p>
              </div>
              <div class="rounded-full bg-indigo-100 p-3 dark:bg-indigo-900/20"><span class="text-2xl">👤</span></div>
            </div>
          </div>
          <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Vistas hoy</p>
                <p class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">${data.viewsToday.toLocaleString()}</p>
              </div>
              <div class="rounded-full bg-indigo-100 p-3 dark:bg-indigo-900/20"><span class="text-2xl">📅</span></div>
            </div>
          </div>
        `;

        topPagesEl.innerHTML = data.topPages.length > 0
          ? data.topPages.map((p) => `
            <div class="flex justify-between px-6 py-3">
              <span class="truncate text-sm text-gray-900 dark:text-white" title="${p.path}">${p.path || '/'}</span>
              <span class="ml-2 shrink-0 text-sm font-medium text-gray-600 dark:text-gray-400">${p.count.toLocaleString()}</span>
            </div>
          `).join('')
          : '<div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">No hay datos</div>';

        topLocationsEl.innerHTML = data.topLocations.length > 0
          ? data.topLocations.map((l) => `
            <div class="flex justify-between px-6 py-3">
              <span class="text-sm text-gray-900 dark:text-white">${l.city ? `${l.city}, ` : ''}${l.country}</span>
              <span class="ml-2 shrink-0 text-sm font-medium text-gray-600 dark:text-gray-400">${l.count.toLocaleString()}</span>
            </div>
          `).join('')
          : '<div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">No hay datos</div>';

        recentVisitsEl.innerHTML = data.recentVisits.length > 0
          ? data.recentVisits.map((v) => {
              const loc = [v.city, v.country].filter(Boolean).join(', ') || '—';
              const date = new Date(v.createdAt);
              const dateStr = date.toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' });
              return `
            <div class="px-6 py-3 text-sm">
              <div class="flex justify-between gap-2">
                <span class="font-mono text-gray-700 dark:text-gray-300">${v.ip}</span>
                <span class="shrink-0 text-gray-500 dark:text-gray-400">${dateStr}</span>
              </div>
              <div class="mt-1 truncate text-gray-600 dark:text-gray-400">${v.path}</div>
              <div class="mt-0.5 text-xs text-gray-500 dark:text-gray-500">${loc}</div>
            </div>
          `;
            }).join('')
          : '<div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">No hay visitas recientes</div>';
      } catch (err) {
        console.error('Error loading analytics:', err);
        cardsEl.innerHTML = '<div class="col-span-3 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700 dark:border-red-800 dark:bg-red-900/20 dark:text-red-400">Error al cargar analytics. Verifica que estés autenticado como admin.</div>';
        topPagesEl.innerHTML = '<div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">—</div>';
        topLocationsEl.innerHTML = '<div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">—</div>';
        recentVisitsEl.innerHTML = '<div class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">—</div>';
      }
    })();
  </script>
</AdminLayout>

