---
import AdminLayout from '@components/admin/AdminLayout.astro';
import OAuthProviderCard from '@components/admin/OAuthProviderCard';
---

<AdminLayout title="Configuración OAuth">
  <div class="space-y-6">
    <!-- Header -->
    <div>
      <div class="flex items-center mb-2">
        <a
          href="/admin/services"
          class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white mr-2"
        >
          ← Servicios
        </a>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
        OAuth Social Login
      </h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        Configura los proveedores OAuth para permitir que los usuarios hagan login en tu sitio
      </p>
    </div>

    <!-- Info Banner -->
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
      <div class="flex items-start">
        <div class="text-2xl mr-3">ℹ️</div>
        <div class="flex-1">
          <h3 class="text-sm font-medium text-blue-900 dark:text-blue-100">
            Importante
          </h3>
          <p class="mt-1 text-sm text-blue-700 dark:text-blue-300">
            El backend debe ser accesible públicamente para que los callbacks OAuth funcionen.
            Las URLs de callback deben coincidir exactamente con las configuradas en Google Cloud Console o GitHub.
          </p>
        </div>
      </div>
    </div>

    <!-- Providers -->
    <div class="space-y-6">
      <OAuthProviderCard
        client:load
        provider="google"
        title="Google OAuth"
        description="Permite a los usuarios hacer login con su cuenta de Google"
        icon="🔐"
      />

      <OAuthProviderCard
        client:load
        provider="github"
        title="GitHub OAuth"
        description="Permite a los usuarios hacer login con su cuenta de GitHub"
        icon="🔐"
      />
    </div>

    <!-- Additional Help -->
    <div class="bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-lg p-6">
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">
        📚 Guías de Configuración
      </h3>
      <div class="space-y-3">
        <div>
          <h4 class="font-medium text-gray-900 dark:text-white">Google OAuth</h4>
          <ol class="mt-2 text-sm text-gray-600 dark:text-gray-400 list-decimal list-inside space-y-1">
            <li>Ve a <a href="https://console.cloud.google.com" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline">Google Cloud Console</a></li>
            <li>Crea un proyecto o selecciona uno existente</li>
            <li>Habilita Google+ API</li>
            <li>En "Credenciales", crea credenciales OAuth 2.0</li>
            <li>Agrega las URLs de callback autorizadas</li>
          </ol>
        </div>
        <div>
          <h4 class="font-medium text-gray-900 dark:text-white">GitHub OAuth</h4>
          <ol class="mt-2 text-sm text-gray-600 dark:text-gray-400 list-decimal list-inside space-y-1">
            <li>Ve a <a href="https://github.com/settings/developers" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline">GitHub Developer Settings</a></li>
            <li>Click en "New OAuth App"</li>
            <li>Completa el formulario con tu información</li>
            <li>Agrega la callback URL</li>
            <li>Copia el Client ID y genera un Client Secret</li>
          </ol>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
