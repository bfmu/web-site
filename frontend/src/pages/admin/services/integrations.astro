---
import AdminLayout from '@components/admin/AdminLayout.astro';
import SpotifyIntegrationCard from '@components/admin/SpotifyIntegrationCard';
---

<AdminLayout title="Integraciones API">
  <div class="space-y-6">
    <!-- Header -->
    <div>
      <div class="flex items-center mb-2">
        <a
          href="/admin/services"
          class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white mr-2"
        >
          ← Servicios
        </a>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
        Integraciones de API
      </h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        Conecta servicios externos para mostrar información personalizada en tu sitio
      </p>
    </div>

    <!-- Info Banner -->
    <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-4">
      <div class="flex items-start">
        <div class="text-2xl mr-3">⚠️</div>
        <div class="flex-1">
          <h3 class="text-sm font-medium text-yellow-900 dark:text-yellow-100">
            Nota importante sobre Spotify
          </h3>
          <p class="mt-1 text-sm text-yellow-700 dark:text-yellow-300">
            Esta integración es para mostrar TUS estadísticas personales de Spotify, no es un sistema de login para usuarios.
            Solo necesitas configurarlo una vez y el backend actualizará los tokens automáticamente.
          </p>
        </div>
      </div>
    </div>

    <!-- Integrations -->
    <div class="space-y-6">
      <SpotifyIntegrationCard client:load />
    </div>

    <!-- Additional Help -->
    <div class="bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-lg p-6">
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">
        📚 Guía de Configuración de Spotify
      </h3>
      <div class="space-y-3">
        <div>
          <h4 class="font-medium text-gray-900 dark:text-white">Paso 1: Crear App en Spotify</h4>
          <ol class="mt-2 text-sm text-gray-600 dark:text-gray-400 list-decimal list-inside space-y-1">
            <li>Ve a <a href="https://developer.spotify.com/dashboard" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline">Spotify Developer Dashboard</a></li>
            <li>Click en "Create app"</li>
            <li>Completa el formulario (nombre, descripción, etc.)</li>
            <li>En "Redirect URIs", agrega la URL que aparece en el formulario arriba</li>
            <li>Guarda y copia el Client ID y Client Secret</li>
          </ol>
        </div>
        <div>
          <h4 class="font-medium text-gray-900 dark:text-white">Paso 2: Configurar en el Dashboard</h4>
          <ol class="mt-2 text-sm text-gray-600 dark:text-gray-400 list-decimal list-inside space-y-1">
            <li>Pega el Client ID y Client Secret en los campos de arriba</li>
            <li>Click en "Autorizar con Spotify"</li>
            <li>Inicia sesión en Spotify y acepta los permisos</li>
            <li>El refresh token se copiará automáticamente</li>
            <li>Click en "Guardar Configuración"</li>
          </ol>
        </div>
        <div>
          <h4 class="font-medium text-gray-900 dark:text-white">Paso 3: Verificar</h4>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Usa el botón "Probar Conexión" para verificar que todo funciona correctamente.
            Si ves tu perfil de Spotify, ¡todo está configurado!
          </p>
        </div>
      </div>
    </div>

    <!-- What you can show -->
    <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-6">
      <h3 class="text-lg font-medium text-green-900 dark:text-green-100 mb-4">
        ✨ Qué puedes mostrar en tu sitio
      </h3>
      <ul class="space-y-2 text-sm text-green-700 dark:text-green-300">
        <li>🎵 Top tracks (canciones más escuchadas)</li>
        <li>🎤 Top artists (artistas más escuchados)</li>
        <li>🕐 Recently played (últimas canciones reproducidas)</li>
        <li>📝 Playlists públicas</li>
        <li>👤 Información de perfil</li>
      </ul>
      <p class="mt-4 text-sm text-green-700 dark:text-green-300">
        Los datos se actualizan automáticamente cada vez que alguien visita tu sitio.
      </p>
    </div>
  </div>
</AdminLayout>
