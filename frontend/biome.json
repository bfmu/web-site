{
  "$schema": "https://biomejs.dev/schemas/1.8.3/schema.json",
  "extends": [],
  "files": { "ignoreUnknown": true },
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "ignore": ["src/config.ts"],
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "asNeeded",
      "arrowParentheses": "asNeeded"
    }
  },
  "json": {
    "parser": { "allowComments": true },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 80
    }
  },
  "linter": {
    "ignore": ["src/plugins"],
    "rules": {
      "a11y": {
        "recommended": true,
        "useButtonType": "off",
        "noSvgWithoutTitle": "off",
        "noLabelWithoutControl": "off",
        "useKeyWithClickEvents": "off",
        "useSemanticElements": "off"
      },
      "complexity": {
        "recommended": true,
        "noForEach": "off",
        "useOptionalChain": "off",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "recommended": true,
        "useExhaustiveDependencies": "off"
      },
      "performance": {
        "recommended": true
      },
      "security": {
        "recommended": true
      },
      "style": {
        "recommended": true,
        "noParameterAssign": "off",
        "useSelfClosingElements": "off",
        "useTemplate": "off",
        "useSingleVarDeclarator": "off",
        "useNodejsImportProtocol": "off",
        "noUnusedTemplateLiteral": "off"
      },
      "suspicious": {
        "recommended": true,
        "noExplicitAny": "off",
        "noArrayIndexKey": "off"
      },
      "nursery": {
        "recommended": true,
        "useConsistentMemberAccessibility": "off",
        "useAriaPropsSupportedByRole": "off"
      }
    }
  }
}
