# ====================
# Variables de Entorno - Producción Frontend Admin
# API: https://api.bfmu.dev/api
# ====================

# 🌐 API Configuration
NODE_ENV=production
API_URL=https://api.bfmu.dev/api
APP_NAME=Blog Admin Panel
APP_VERSION=1.0.0

# 🔑 OAuth Configuration (configurar con tus valores reales)
# IMPORTANTE: Solo incluir Client IDs públicos, NO secretos
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GITHUB_CLIENT_ID=tu-github-client-id
GOOGLE_REDIRECT_URL=https://admin.bfmu.dev/auth/callback
GITHUB_REDIRECT_URL=https://admin.bfmu.dev/auth/callback

# 🎛️ Feature Flags (producción - restrictivo)
ENABLE_REGISTRATION=false
ENABLE_OAUTH=true
ENABLE_DEBUG_MODE=false
SHOW_DRAFT_POSTS=false

# 🎨 UI Configuration (producción - optimizado)
ITEMS_PER_PAGE=20
MAX_FILE_SIZE=10485760
UI_THEME=light

# ⚡ Cache Configuration (en millisegundos - producción - más tiempo)
CACHE_USER_PROFILE=900000
CACHE_BLOG_POSTS=300000
CACHE_CATEGORIES=1800000

# 🔒 Security & Performance
ENABLE_ANALYTICS=true
SECURE_COOKIES=true
ENABLE_HTTPS=true

# 🌍 Deployment Configuration
APP_DOMAIN=admin.bfmu.dev
STATIC_CACHE_TTL=31536000
API_CACHE_TTL=300

# 📊 Logging & Monitoring
LOG_LEVEL=info
SENTRY_DSN=
ANALYTICS_ID=
