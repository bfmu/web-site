# Archivo de ejemplo para variables de entorno en PRODUCCIÓN
# Copia este archivo a .env y configura los valores reales

# MongoDB
MONGO_USERNAME=admin
MONGO_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO

# JWT Secrets (IMPORTANTE: Usa valores únicos y seguros)
JWT_SECRET=CAMBIA_ESTO_POR_SECRET_MUY_SEGURO_MIN_32_CARACTERES
JWT_REFRESH_SECRET=CAMBIA_ESTO_POR_OTRO_SECRET_MUY_SEGURO_MIN_32_CARACTERES

# Encryption para secrets en MongoDB (IMPORTANTE: Genera una clave de 32 caracteres)
ENCRYPTION_KEY=CAMBIA_ESTO_POR_KEY_32_CARACTERES

# URL del sitio web (links de compartir, sitemap, Open Graph, etc.)
PUBLIC_WEB_SITE_URL=https://tudominio.com
WEB_SITE_URL=https://tudominio.com

# URL del backend (API, imágenes). En producción con nginx proxy, suele ser la misma que WEB_SITE_URL.
PUBLIC_BACKEND_URL=https://tudominio.com

# Frontend Admin URL
FRONTEND_ADMIN_URL=https://tudominio.com

# ============================================================
# OAuth y Spotify (OPCIONAL - Configurables desde dashboard)
# ============================================================
# Si no configuras aquí, DEBES configurar desde /admin/services
# después del primer despliegue. Estos valores son FALLBACK.
# ============================================================

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://tudominio.com/api/auth/google/callback

# GitHub OAuth (opcional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://tudominio.com/api/auth/github/callback

# Spotify Integration (opcional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://tudominio.com/api/spotify/callback
SPOTIFY_REFRESH_TOKEN=

# ============================================================
# Grafana / Loki (visor de logs)
# ============================================================
# Grafana en subdominio (ej: grafana.tudominio.com) para evitar redirect loop en v10
# Requiere: 1) Proxy en NPM para grafana.tudominio.com -> website-nginx:80
#           2) DNS: grafana.tudominio.com apunte al servidor
# Se usa para: GF_SERVER_ROOT_URL de Grafana y enlace "Logs" en el admin
GRAFANA_PUBLIC_URL=https://grafana.tudominio.com/
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO
