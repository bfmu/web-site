# ============================================
# CONFIGURACIÓN PARA DOCKER COMPOSE
# ============================================
# Copia este archivo a .env y configura los valores

# Backend - MongoDB (usar 'mongodb' como hostname dentro de Docker)
MONGODB_URI=mongodb://admin:admin123@mongodb:27017/blog?authSource=admin
PORT=4000
JWT_SECRET=tu-jwt-secret-super-seguro-aqui
GOOGLE_CLIENT_ID=tu-google-client-id
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GITHUB_CLIENT_ID=tu-github-client-id
GITHUB_CLIENT_SECRET=tu-github-client-secret

# Frontend - Desarrollo con Docker
# URL del backend (desde el navegador usa localhost, desde SSR en Docker usa backend:3000)
PUBLIC_BACKEND_URL=http://localhost:3000/
PUBLIC_BACKEND_URL_SSR=http://backend:3000/
# URL del sitio para links de compartir
PUBLIC_WEB_SITE_URL=http://localhost:4321/

